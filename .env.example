APP_ENV=dev
APP_LOG_LEVEL=INFO
APP_LOG_FORMAT=json
APP_JWT_SECRET_KEY=change-me-in-production
APP_ACCESS_TOKEN_EXPIRE_MINUTES=60

APP_DEMO_USERNAME=demo
# Option A (recommended): hashed password generated by scripts/generate_password_hash.py
APP_DEMO_PASSWORD_HASH=
# Option B (local demo only)
APP_DEMO_PASSWORD=demo123

APP_CORS_ORIGINS=http://localhost:5173
APP_TRUSTED_HOSTS=localhost,127.0.0.1

APP_QDRANT_URL=http://qdrant:6333
APP_QDRANT_COLLECTION=complyra_private_kb

APP_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# Embedding provider: "sentence-transformers" (default, local) or "openai" (API)
APP_EMBEDDING_PROVIDER=sentence-transformers
APP_OPENAI_API_KEY=
APP_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# 384 for BGE-small, 1536 for OpenAI text-embedding-3-small
APP_EMBEDDING_DIMENSION=384

APP_OLLAMA_BASE_URL=http://ollama:11434
APP_OLLAMA_MODEL=qwen2.5:3b-instruct
APP_OLLAMA_PREPULL=true
APP_OLLAMA_TIMEOUT_SECONDS=60

APP_CHUNK_SIZE=800
APP_CHUNK_OVERLAP=120
APP_TOP_K=4
APP_DEFAULT_TENANT_ID=default

APP_REQUIRE_APPROVAL=true
APP_OUTPUT_POLICY_ENABLED=true
APP_OUTPUT_POLICY_BLOCK_MESSAGE=The generated response was withheld due to policy checks. Please contact an administrator.
# Use || as delimiter when defining multiple regex rules in a single env var.
APP_OUTPUT_POLICY_BLOCK_PATTERNS=AKIA[0-9A-Z]{16}||ASIA[0-9A-Z]{16}||(?:sk|rk)-[A-Za-z0-9]{20,}

APP_DATABASE_URL=postgresql+psycopg://app:app_password@postgres:5432/complyra

APP_SESSION_COOKIE_NAME=complyra_token
APP_COOKIE_SECURE=false
APP_COOKIE_SAMESITE=lax
APP_COOKIE_DOMAIN=

APP_REDIS_URL=redis://redis:6379/0
APP_INGEST_QUEUE_NAME=ingest
APP_INGEST_ASYNC_ENABLED=true
APP_INGEST_MAX_FILE_SIZE_MB=20
APP_INGEST_STORAGE_PATH=./data/uploads
APP_INGEST_ALLOWED_EXTENSIONS=pdf,txt,md

# LangSmith tracing (optional — no-op when disabled)
APP_LANGSMITH_API_KEY=
APP_LANGSMITH_PROJECT=complyra
APP_LANGSMITH_TRACING=false

APP_SENTRY_DSN=
APP_SENTRY_ENVIRONMENT=dev
APP_METRICS_ENABLED=true
APP_METRICS_PATH=/metrics
APP_METRICS_TOKEN=
